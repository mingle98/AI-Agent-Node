# 如果使用阿里云的模型请前往“阿里云官网”获取你的API_KEY: https://bailian.console.aliyun.com/cn-beijing/?tab=model#/api-key

# 服务端口
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# 选择 Embedding 提供商: openai 或 aliyun
EMBEDDING_PROVIDER=aliyun

# 选择 LLM 提供商: openai 或 aliyun
LLM_PROVIDER=aliyun

# 阿里云 DashScope API配置
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DashScope 应用ID（用于 /api/v1/apps/{appId}/completion ）
# DASHSCOPE_APP_ID=your_dashscope_app_id_here

# OpenAI API配置（如果使用 OpenAI 则取消注释并设置）
# OPENAI_API_KEY=your_openai_api_key_here

# Wait 60 seconds before connecting using these details, or login to https://console.neo4j.io to validate the Aura Instance is available
# NEO4J_URI=XXXX
# NEO4J_USERNAME=XXXXX
# NEO4J_PASSWORD=XXXXX
# NEO4J_DATABASE=XXXXX
# AURA_INSTANCEID=XXXXX
# AURA_INSTANCENAME=XXXXX
