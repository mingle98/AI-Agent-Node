{
  "name": "production-agent",
  "version": "1.0.0",
  "type": "module",
  "description": "生产级 AI Agent - 模块化架构（智能客服助手）",
  "main": "index.js",
  "scripts": {
    "dev": "sh -c 'node server.js & SERVER_PID=$!; sleep 7; open http://localhost:3000/aisbc-debug.html; wait $SERVER_PID'",
    "dev:server": "node server.js",
    "test": "c8 --reporter=lcov --reporter=text --reporter=html --exclude=test/** --exclude=node_modules/** --exclude=demos/** --exclude=scripts/** node --test",
    "test:coverage": "c8 --reporter=text-summary --check-coverage --lines=98 --functions=98 --branches=95 --statements=98 --exclude=demos/** --exclude=scripts/** node --test",
    "prepare": "husky"
  },
  "keywords": [
    "ai-agent",
    "langchain",
    "rag",
    "chatbot",
    "customer-service",
    "tools",
    "skills"
  ],
  "author": "",
  "license": "Apache-2.0",
  "dependencies": {
    "@langchain/classic": "^1.0.23",
    "@langchain/community": "^1.1.23",
    "@langchain/core": "^1.1.32",
    "@langchain/openai": "^1.2.13",
    "@langchain/textsplitters": "^1.0.1",
    "archiver": "^7.0.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "epub2": "^3.0.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "faiss-node": "^0.5.1",
    "fs-extra": "^11.3.4",
    "html-to-text": "^9.0.5",
    "langchain": "^1.2.32",
    "mammoth": "^1.12.0",
    "marked": "^17.0.4",
    "multer": "^2.1.1",
    "neo4j-driver": "^5.28.1",
    "nodemailer": "^6.9.15",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "husky": "^9.1.6"
  },
  "engines": {
    "node": ">=20.6.0"
  }
}
